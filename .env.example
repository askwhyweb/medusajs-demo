# PostgreSQL
POSTGRES_USER=medusa
POSTGRES_PASSWORD=medusa
POSTGRES_DB=medusa_demo
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Medusa backend
DATABASE_URL=postgres://medusa:medusa@postgres:5432/medusa_demo
DB_NAME=medusa_demo
REDIS_URL=redis://redis:6379
STORE_CORS=http://localhost:8000,http://127.0.0.1:8000
ADMIN_CORS=http://localhost:9000,http://127.0.0.1:9000
AUTH_CORS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:9000,http://127.0.0.1:9000
JWT_SECRET=change-me
COOKIE_SECRET=change-me
ADMIN_EMAIL=admin@medusa.local
ADMIN_PASSWORD=MedusaDemo123!
MEDUSA_BACKEND_URL=http://localhost:9000
MEDUSA_STOREFRONT_URL=http://localhost:8000
MEDUSA_INTERNAL_BACKEND_URL=http://backend:9000
MEDUSA_INTERNAL_STOREFRONT_URL=http://storefront:8000
WORKER_MODE=shared
RUNTIME_DIR=/runtime

# Storefront
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_DEFAULT_REGION=gb
NEXT_PUBLIC_BASE_URL=http://localhost:8000
NEXT_PUBLIC_STRIPE_KEY=
